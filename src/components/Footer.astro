---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="border-t border-white/5 bg-[#070b18] py-12 mt-24">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <a href={base}>
        <img src={`${base}/images/brands/quantum.svg`} alt="Quantum Infinity" class="h-8" />
      </a>

      <p class="text-white/40 text-sm text-center">
        Parte del grupo <span class="text-white/60 font-semibold">Stage 01</span>
      </p>

      <div class="flex items-center gap-6">
        <a href="mailto:hola@qi.pe" class="text-sm text-white/50 hover:text-[#00d4ff] transition-colors">hola@qi.pe</a>
        <a href="#contacto" class="btn-outline text-xs">Contacto</a>
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-white/5 text-center text-white/25 text-xs">
      © {new Date().getFullYear()} Quantum Infinity. Todos los derechos reservados.
    </div>
  </div>
</footer>
