---
const base = import.meta.env.BASE_URL;
const links = [
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Servicios', href: '#servicios' },
  { label: 'Portafolio', href: '#portafolio' },
  { label: 'Contacto', href: '#contacto' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="navbar">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href={base}>
      <img src={`${base}images/brands/quantum.svg`} alt="Quantum Infinity" class="h-8" />
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <a href={link.href} class="text-sm font-semibold uppercase tracking-widest text-white/70 hover:text-[#00d4ff] transition-colors">
          {link.label}
        </a>
      ))}
    </nav>

    <a href="#contacto" class="btn-outline hidden md:inline-flex text-xs">
      Trabajemos juntos
    </a>

    <button id="menu-btn" class="md:hidden text-white" aria-label="Menu">
      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden px-6 pb-4 flex flex-col gap-4 bg-[#070b18]/95 backdrop-blur">
    {links.map(link => (
      <a href={link.href} class="text-sm font-semibold uppercase tracking-widest text-white/70 hover:text-[#00d4ff] transition-colors">
        {link.label}
      </a>
    ))}
    <a href="#contacto" class="btn-outline w-fit text-xs">Trabajemos juntos</a>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar');
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar?.classList.add('bg-[#070b18]/90', 'backdrop-blur-md', 'border-b', 'border-white/5');
    } else {
      navbar?.classList.remove('bg-[#070b18]/90', 'backdrop-blur-md', 'border-b', 'border-white/5');
    }
  });

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
