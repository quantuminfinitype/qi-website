---
import Layout from '../layouts/Layout.astro';
const b = import.meta.env.BASE_URL.replace(/\/$/, '');

const stats = [
  { value: '+300', label: 'Proyectos' },
  { value: '+80',  label: 'Clientes' },
  { value: '+5M',  label: 'Impactos' },
];

const clients = [
  'utp','pucp','betplay','yape','amd','bitel','continental',
  'aorus','nvidia','logitech','intel','razer','spacefwd',
  'rivalry','valve','claro','acer','moonton',
];

const services = [
  { key: 'estrategia', icon: '▼', label: 'Estrategia &\nCampañas' },
  { key: 'talentos',   icon: '◆', label: 'Talentos\n& Comunidad' },
  { key: 'produccion', icon: '+', label: 'Producción &\nContenido' },
  { key: 'eventos',    icon: '●', label: 'Eventos &\nExperiencias en Vivo' },
];

const values = [
  { num: '01', title: 'Nada\nes relleno',       desc: 'Hasta lo que no se ve' },
  { num: '02', title: 'Hecho para\nvivirse',     desc: 'Cada decisión empieza por la experiencia' },
  { num: '03', title: 'Bueno no es\nsuficiente', desc: 'El estándar no se negocia' },
];

const brands = [
  { key: 'brandora', name: 'Brandora',         role: 'Agencia de Marketing',     tags: 'Estrategia · Campaña · Marca' },
  { key: 'wonder',   name: 'Wonder',           role: 'Productora de Eventos',    tags: 'Experiencia · Activaciones · BTL' },
  { key: 'intercut', name: 'Intercut Media',   role: 'Productora Audiovisual',   tags: 'Ideas · Contenido · Todo Formato' },
  { key: 'quantum',  name: 'Quantum Infinity', role: 'Entretenimiento & Gaming', tags: 'Juego · Cultura · Comunidad' },
];
---

<Layout title="Quantum Infinity — Entertainment Powered by Gaming">

<!-- ═══════════════════════════════════ HERO ═══════════════════════════════════ -->
<section style="position:relative;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:flex-start;text-align:center;padding:120px 40px 0;overflow:hidden;">

  <div style="position:relative;z-index:10;max-width:1000px;width:100%;display:flex;flex-direction:column;align-items:center;">

    <!-- tag pill -->
    <span style="display:inline-flex;align-items:center;border:1.5px solid #40DCFF;color:#40DCFF;padding:14px 40px;border-radius:9999px;font-family:'eurostile',sans-serif;font-size:0.6rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:48px;">
      No existen recetas secretas
    </span>

    <!-- main title -->
    <h1 style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(3.8rem,10vw,9.5rem);text-transform:uppercase;line-height:0.88;letter-spacing:-0.01em;margin:0;width:100%;">
      <span class="gradient-text" style="display:block;">Entertainment</span>
      <span style="color:white;display:block;">Powered by Gaming</span>
    </h1>
  </div>

  <!-- GAMING ES section — ghost words behind foreground text -->
  <div style="position:relative;width:100%;max-width:1000px;margin-top:56px;padding-bottom:80px;">

    <!-- ghost words background -->
    <div aria-hidden="true" style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;pointer-events:none;user-select:none;gap:0;">
      <div style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(1.6rem,4.5vw,4rem);letter-spacing:0.04em;text-transform:uppercase;color:rgba(255,255,255,0.04);line-height:1.2;">CULTURA</div>
      <div style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(1.6rem,4.5vw,4rem);letter-spacing:0.04em;text-transform:uppercase;color:rgba(255,255,255,0.06);line-height:1.2;">EXPERIENCIA</div>
      <div style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(1.6rem,4.5vw,4rem);letter-spacing:0.04em;text-transform:uppercase;color:rgba(255,255,255,0.04);line-height:1.2;">ENTRETENIMIENTO</div>
      <div style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(1.6rem,4.5vw,4rem);letter-spacing:0.04em;text-transform:uppercase;color:rgba(255,255,255,0.03);line-height:1.2;">COMUNIDAD</div>
      <div style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(1.6rem,4.5vw,4rem);letter-spacing:0.04em;text-transform:uppercase;color:rgba(255,255,255,0.025);line-height:1.2;">CREATIVIDAD</div>
    </div>

    <!-- foreground "GAMING ES" text -->
    <div style="position:relative;z-index:10;text-align:center;padding:32px 0;">
      <p style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(1.4rem,3.5vw,2.8rem);text-transform:uppercase;letter-spacing:0.03em;color:white;line-height:1;">
        Gaming es <span style="color:#40DCFF;">Entretenimiento</span>
      </p>
    </div>
  </div>

  <!-- scroll indicator -->
  <a href="#nosotros" aria-label="Scroll" style="position:absolute;bottom:36px;left:50%;transform:translateX(-50%);animation:bounce 2s infinite;opacity:0.5;z-index:20;">
    <svg width="18" height="18" fill="none" stroke="#40DCFF" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
    </svg>
  </a>
</section>

<!-- ═══════════════════════════════════ VALUES ════════════════════════════════ -->
<section id="nosotros" style="padding:80px 40px 100px;">
  <div style="max-width:1120px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:16px;">
    {values.map(v => (
      <div style="background:rgba(15,14,21,0.5);border:1px solid rgba(64,220,255,0.18);border-radius:18px;padding:37px 32px 60px;transition:border-color 0.3s;"
        onmouseover="this.style.borderColor='rgba(64,220,255,0.4)'" onmouseout="this.style.borderColor='rgba(64,220,255,0.18)'">
        <div style="font-family:'eurostile',sans-serif;font-weight:900;font-size:1.1rem;color:#40DCFF;letter-spacing:0.1em;margin-bottom:20px;">{v.num}</div>
        <h3 style="font-family:'eurostile',sans-serif;font-weight:900;font-size:1.3rem;text-transform:uppercase;color:white;line-height:1.15;margin:0 0 16px;letter-spacing:0.01em;white-space:pre-line;">{v.title}</h3>
        <p style="font-family:'eurostile',sans-serif;font-size:0.9rem;color:rgb(159,159,159);line-height:1.65;margin:0;">{v.desc}</p>
      </div>
    ))}
  </div>
</section>

<!-- ════════════════════════════════ SERVICES ════════════════════════════════ -->
<section id="servicios" style="padding:20px 40px 100px;">
  <div style="max-width:1120px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:20px;">
      <span style="display:inline-flex;align-items:center;border:1.5px solid #40DCFF;color:#40DCFF;padding:14px 40px;border-radius:9999px;font-family:'eurostile',sans-serif;font-size:0.6rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;">
        Nuestro diferencial
      </span>
    </div>
    <h2 style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(2rem,4.5vw,3.6rem);text-transform:uppercase;text-align:center;color:white;letter-spacing:0.01em;line-height:1;margin:28px 0 40px;">
      Lo que hacemos mejor que nadie
    </h2>
    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:12px;">
      {services.map(s => (
        <div class="service-tile" style="position:relative;overflow:hidden;border-radius:18px;cursor:pointer;">
          <img src={`${b}/images/services/${s.key}.png`} alt={s.label}
            style="width:100%;height:280px;object-fit:cover;display:block;transition:transform 0.6s ease;" />
          <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.75) 0%,rgba(0,0,0,0.1) 50%,transparent 100%);"></div>
          <div style="position:absolute;bottom:0;left:0;padding:22px 26px;display:flex;align-items:flex-end;gap:10px;">
            <span style="color:#40DCFF;font-weight:900;font-size:1rem;line-height:1;flex-shrink:0;">{s.icon}</span>
            <span style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(0.85rem,1.5vw,1.05rem);text-transform:uppercase;color:white;letter-spacing:0.06em;line-height:1.2;white-space:pre-line;">{s.label}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════════════════════════════════ STATS ═══════════════════════════════════ -->
<section style="padding:100px 40px;border-top:1px solid rgba(255,255,255,0.06);">
  <div style="max-width:860px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:20px;text-align:center;">
    {stats.map(s => (
      <div>
        <div style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(4rem,9vw,7.5rem);color:#40DCFF;line-height:1;letter-spacing:-0.02em;">{s.value}</div>
        <div style="font-family:'eurostile',sans-serif;font-weight:900;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.22em;color:white;margin-top:10px;">{s.label}</div>
      </div>
    ))}
  </div>
</section>

<!-- ════════════════════════════════ CLIENTS ═════════════════════════════════ -->
<section style="padding:60px 40px 80px;">
  <div style="max-width:1000px;margin:0 auto;">
    <div style="display:flex;flex-wrap:wrap;justify-content:center;align-items:center;gap:20px 48px;margin-bottom:60px;">
      {clients.map(c => (
        <img src={`${b}/images/clients/${c}.svg`} alt={c}
          style="height:18px;object-fit:contain;opacity:0.45;filter:brightness(10);transition:opacity 0.3s;cursor:default;"
          onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='0.45'" />
      ))}
    </div>
    <div style="text-align:center;">
      <a href="#portafolio" style="display:inline-flex;align-items:center;justify-content:center;border:1.5px solid #40DCFF;color:white;padding:16px 48px;border-radius:9999px;font-family:'eurostile',sans-serif;font-size:0.62rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;text-decoration:none;transition:background 0.2s,color 0.2s;"
        onmouseover="this.style.background='#40DCFF';this.style.color='#000'" onmouseout="this.style.background='transparent';this.style.color='white'">
        Ver portafolio de experiencias
      </a>
    </div>
  </div>
</section>

<!-- ════════════════════════════ QUANTUM STUDIOS ════════════════════════════ -->
<section style="overflow:hidden;margin:0 0 0;">
  <div style="display:grid;grid-template-columns:42fr 58fr;min-height:420px;max-width:100%;">

    <!-- text side -->
    <div style="padding:72px 64px;display:flex;flex-direction:column;justify-content:center;background:rgba(4,6,16,0.85);">
      <h2 style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(1.6rem,3vw,2.4rem);text-transform:uppercase;color:white;line-height:1;letter-spacing:0.02em;margin:0 0 16px;">Quantum Studios</h2>
      <p style="font-family:'eurostile',sans-serif;font-size:0.82rem;color:rgba(255,255,255,0.45);line-height:1.8;margin:0 0 36px;">
        Un espacio para crear sin límites.<br/>Ubicado en el corazón de Lima, Perú.
      </p>
      <div>
        <a href="#contacto" style="display:inline-flex;align-items:center;justify-content:center;border:1.5px solid rgba(255,255,255,0.3);color:white;padding:14px 36px;border-radius:9999px;font-family:'eurostile',sans-serif;font-size:0.62rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;text-decoration:none;background:rgba(15,14,21,0.5);transition:border-color 0.2s;"
          onmouseover="this.style.borderColor='rgba(255,255,255,0.6)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.3)'">
          Ver estudio
        </a>
      </div>
    </div>

    <!-- photo side -->
    <div style="position:relative;overflow:hidden;">
      <img src={`${b}/images/quantum-studios.png`} alt="Quantum Studios"
        style="width:100%;height:100%;object-fit:cover;object-position:center top;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(to right,rgba(4,6,16,0.6) 0%,transparent 35%);"></div>
    </div>
  </div>
</section>

<!-- ════════════════════════════════ STAGE 01 ════════════════════════════════ -->
<section style="padding:100px 40px;text-align:center;background:rgba(4,5,14,0.7);">
  <div style="max-width:1120px;margin:0 auto;">
    <img src={`${b}/images/brands/stage01.svg`} alt="Stage 01"
      style="height:72px;margin:0 auto 32px;display:block;object-fit:contain;filter:brightness(10);opacity:0.9;" />

    <span style="display:inline-flex;align-items:center;border:1.5px solid #40DCFF;color:#40DCFF;padding:14px 40px;border-radius:9999px;font-family:'eurostile',sans-serif;font-size:0.6rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;">
      El poder de crear, conectar y entretener
    </span>

    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:56px;">
      {brands.map(br => (
        <div style="background:rgba(15,14,21,0.5);border:1px solid rgba(64,220,255,0.12);border-radius:18px;padding:40px 20px 36px;text-align:center;transition:border-color 0.3s;"
          onmouseover="this.style.borderColor='rgba(64,220,255,0.35)'" onmouseout="this.style.borderColor='rgba(64,220,255,0.12)'">
          <img src={`${b}/images/brands/${br.key}.svg`} alt={br.name}
            style="height:34px;margin:0 auto 20px;display:block;object-fit:contain;filter:brightness(10);" />
          <p style="font-family:'eurostile',sans-serif;font-weight:700;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.06em;color:white;margin:0 0 8px;">{br.role}</p>
          <p style="font-family:'eurostile',sans-serif;font-size:0.6rem;color:rgba(255,255,255,0.3);letter-spacing:0.02em;">{br.tags}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════════════════════════════════ PORTFOLIO ═══════════════════════════════ -->
<section id="portafolio" style="padding:120px 40px;text-align:center;border-top:1px solid rgba(255,255,255,0.05);">
  <div style="max-width:760px;margin:0 auto;">
    <span style="display:inline-flex;align-items:center;border:1.5px solid #40DCFF;color:#40DCFF;padding:12px 36px;border-radius:9999px;font-family:'eurostile',sans-serif;font-size:0.6rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:32px;">
      Portafolio
    </span>
    <h2 style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(2.8rem,7vw,5.5rem);text-transform:uppercase;line-height:0.9;letter-spacing:0.01em;margin:0 0 24px;">
      Experiencias que<br/><span class="gradient-text">dejan huella</span>
    </h2>
    <p style="font-family:'eurostile',sans-serif;font-size:0.82rem;color:rgba(255,255,255,0.38);max-width:480px;margin:0 auto 52px;line-height:1.8;">
      Más de 300 proyectos para las marcas más importantes del ecosistema gaming y entretenimiento en Latinoamérica.
    </p>
    <a href="#contacto" style="display:inline-flex;align-items:center;justify-content:center;border:1.5px solid #40DCFF;color:white;padding:16px 48px;border-radius:9999px;font-family:'eurostile',sans-serif;font-size:0.62rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;text-decoration:none;transition:background 0.2s,color 0.2s;"
      onmouseover="this.style.background='#40DCFF';this.style.color='#000'" onmouseout="this.style.background='transparent';this.style.color='white'">
      Solicitar portafolio completo
    </a>
  </div>
</section>

<!-- ════════════════════════════════ CONTACT ═════════════════════════════════ -->
<section id="contacto" style="position:relative;padding:140px 40px;text-align:center;overflow:hidden;min-height:80vh;display:flex;align-items:center;justify-content:center;">

  <!-- giant decorative Q -->
  <div aria-hidden="true" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none;">
    <svg viewBox="0 0 400 400" style="width:min(680px,90vw);height:min(680px,90vw);opacity:0.035;" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M200 40C111.6 40 40 111.6 40 200C40 288.4 111.6 360 200 360C245.2 360 286.2 341.6 316 312L340 336L360 316L336 292C354 263.2 364 229 364 200C364 111.6 288.4 40 200 40ZM200 320C133.7 320 80 266.3 80 200C80 133.7 133.7 80 200 80C266.3 80 320 133.7 320 200C320 226.8 311.4 251.6 296.6 271.6L264 239L244 259L276.6 291.6C257.4 308.6 232.8 320 200 320Z" fill="white"/>
    </svg>
  </div>

  <div style="position:relative;z-index:10;max-width:660px;width:100%;">
    <h2 style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(3rem,8vw,6.5rem);text-transform:uppercase;line-height:0.88;letter-spacing:0em;margin:0 0 60px;">
      Hagamos algo<br/>
      <span class="gradient-text">Épico</span>
      <span style="color:white;"> Juntos</span>
    </h2>

    <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
      <a href="https://wa.me/51999999999" target="_blank" rel="noopener"
        style="display:inline-flex;align-items:center;justify-content:center;border:1.5px solid rgba(255,255,255,0.3);color:white;padding:16px 44px;border-radius:9999px;font-family:'eurostile',sans-serif;font-size:0.65rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;text-decoration:none;transition:border-color 0.2s,background 0.2s;"
        onmouseover="this.style.borderColor='white';this.style.background='rgba(255,255,255,0.08)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.3)';this.style.background='transparent'">
        WhatsApp
      </a>
      <a href="mailto:hola@qi.pe"
        style="display:inline-flex;align-items:center;justify-content:center;border:1.5px solid rgba(255,255,255,0.3);color:white;padding:16px 44px;border-radius:9999px;font-family:'eurostile',sans-serif;font-size:0.65rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;text-decoration:none;transition:border-color 0.2s,background 0.2s;"
        onmouseover="this.style.borderColor='white';this.style.background='rgba(255,255,255,0.08)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.3)';this.style.background='transparent'">
        Email
      </a>
      <a href="https://t.me/quantuminfinity" target="_blank" rel="noopener"
        style="display:inline-flex;align-items:center;justify-content:center;border:1.5px solid rgba(255,255,255,0.3);color:white;padding:16px 44px;border-radius:9999px;font-family:'eurostile',sans-serif;font-size:0.65rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;text-decoration:none;transition:border-color 0.2s,background 0.2s;"
        onmouseover="this.style.borderColor='white';this.style.background='rgba(255,255,255,0.08)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.3)';this.style.background='transparent'">
        Telegram
      </a>
    </div>
  </div>
</section>

</Layout>

<style>
  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(8px); }
  }
  .service-tile:hover img { transform: scale(1.04); }

  @media (max-width: 768px) {
    /* values */
    #nosotros > div { grid-template-columns: 1fr !important; }
    /* services */
    #servicios .service-grid { grid-template-columns: 1fr !important; }
    /* stage01 brands */
    .brands-grid { grid-template-columns: repeat(2,1fr) !important; }
    /* quantum studios */
    .studios-grid { grid-template-columns: 1fr !important; }
    .studios-img { min-height: 260px; }
  }
</style>
