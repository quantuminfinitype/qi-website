---
import Layout from '../layouts/Layout.astro';
const b = import.meta.env.BASE_URL.replace(/\/$/, '');

const stats = [
  { value: '+300', label: 'Proyectos' },
  { value: '+80',  label: 'Clientes' },
  { value: '+5M',  label: 'Impactos' },
];

const clients = [
  'utp','pucp','betplay','yape','amd','bitel','continental',
  'aorus','nvidia','logitech','intel','razer','spacefwd',
  'rivalry','valve','claro','acer','moonton',
];

const services = [
  { key: 'estrategia', icon: '▼', label: 'Estrategia & Campañas' },
  { key: 'talentos',   icon: '◆', label: 'Talentos & Comunidad' },
  { key: 'produccion', icon: '+', label: 'Producción & Contenido' },
  { key: 'eventos',    icon: '●', label: 'Eventos & Experiencias en Vivo' },
];

const values = [
  { num: '01', title: 'Nada\nes relleno',          desc: 'Hasta lo que no se ve' },
  { num: '02', title: 'Hecho para\nvivirse',        desc: 'Cada decisión empieza por la experiencia' },
  { num: '03', title: 'Bueno no es\nsuficiente',    desc: 'El estándar no se negocia' },
];

const brands = [
  { key: 'brandora', role: 'Agencia de Marketing',     tags: 'Estrategia · Campaña · Marca' },
  { key: 'wonder',   role: 'Productora de Eventos',    tags: 'Experiencia · Activaciones · BTL' },
  { key: 'intercut', role: 'Productora Audiovisual',   tags: 'Ideas · Contenido · Todo Formato' },
  { key: 'quantum',  role: 'Entretenimiento & Gaming', tags: 'Juego · Cultura · Comunidad' },
];
---

<Layout title="Quantum Infinity — Entertainment Powered by Gaming">

<!-- ═══════════════════ HERO ═══════════════════ -->
<section id="hero" style="
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 140px 24px 100px;
  overflow: hidden;
">
  <!-- decorative gradient band -->
  <div style="
    position: absolute;
    left: 0; right: 0;
    top: 35%; height: 30%;
    background: linear-gradient(180deg,
      rgba(13,13,13,0) 6%,
      rgba(42,44,145,0.25) 38%,
      rgba(112,47,204,0.3) 52%,
      rgba(22,61,113,0.2) 60%,
      rgba(13,13,13,0) 91%
    );
    pointer-events: none;
  "></div>

  <!-- ghost background words -->
  <div style="
    position: absolute; inset: 0;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    pointer-events: none; user-select: none;
    gap: 0;
  ">
    {['CULTURA','EXPERIENCIA','COMUNIDAD','CREATIVIDAD','ESTRATEGIA'].map((w, i) => (
      <div style={`
        font-family: 'eurostile', sans-serif;
        font-weight: 900;
        font-size: clamp(2.5rem, 6vw, 5.5rem);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        line-height: 1.15;
        color: rgba(255,255,255,${0.025 + i * 0.012});
      `}>{w}</div>
    ))}
  </div>

  <div style="position: relative; z-index: 10; max-width: 960px; width: 100%;">
    <span class="tag" style="margin-bottom: 36px; display: inline-flex;">No existen recetas secretas</span>

    <h1 style="
      font-family: 'eurostile', sans-serif;
      font-weight: 900;
      font-size: clamp(4rem, 10vw, 9rem);
      text-transform: uppercase;
      line-height: 0.92;
      letter-spacing: 0.01em;
      margin: 0 0 32px;
    ">
      <span class="gradient-text" style="display: block;">Entertainment</span>
      <span style="color: white; display: block;">Powered by Gaming</span>
    </h1>

    <p style="
      font-family: 'eurostile', sans-serif;
      font-size: clamp(0.9rem, 1.5vw, 1.1rem);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: rgba(255,255,255,0.45);
      margin: 0 0 48px;
    ">
      Gaming es <span style="color: rgba(255,255,255,0.8);">Entretenimiento</span>
      &nbsp;&nbsp;·&nbsp;&nbsp;
      <span style="color: rgba(255,255,255,0.25);">Cultura · Experiencia · Comunidad</span>
    </p>

    <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
      <a href="#servicios" class="btn-cyan">Ver servicios</a>
      <a href="#contacto" class="btn-ghost">Trabajemos juntos</a>
    </div>
  </div>

  <div style="position: absolute; bottom: 36px; left: 50%; transform: translateX(-50%); animation: bounce 2s infinite;">
    <svg width="18" height="18" fill="none" stroke="#40DCFF" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>

<!-- ═══════════════════ STATS ═══════════════════ -->
<section id="nosotros" style="
  padding: 80px 24px;
  border-top: 1px solid rgba(255,255,255,0.06);
  border-bottom: 1px solid rgba(255,255,255,0.06);
">
  <div style="max-width: 820px; margin: 0 auto; display: grid; grid-template-columns: repeat(3,1fr); gap: 32px; text-align: center;">
    {stats.map(s => (
      <div>
        <div style="
          font-family: 'eurostile', sans-serif;
          font-weight: 900;
          font-size: clamp(3.5rem, 8vw, 6.5rem);
          color: #40DCFF;
          line-height: 1;
          letter-spacing: -0.01em;
        ">{s.value}</div>
        <div style="
          font-family: 'eurostile', sans-serif;
          font-weight: 700;
          font-size: 0.72rem;
          text-transform: uppercase;
          letter-spacing: 0.22em;
          color: white;
          margin-top: 10px;
        ">{s.label}</div>
      </div>
    ))}
  </div>
</section>

<!-- ═══════════════════ CLIENTS ═══════════════════ -->
<section style="padding: 80px 24px;">
  <div style="max-width: 1060px; margin: 0 auto;">
    <p style="
      text-align: center;
      font-family: 'eurostile', sans-serif;
      font-size: 0.6rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.22em;
      color: rgba(255,255,255,0.3);
      margin-bottom: 52px;
    ">Marcas que han confiado en nosotros</p>

    <div style="display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: 28px 48px;">
      {clients.map(c => (
        <img
          src={`${b}/images/clients/${c}.svg`}
          alt={c}
          style="height: 22px; object-fit: contain; opacity: 0.45; filter: brightness(10); transition: opacity 0.3s;"
          onmouseover="this.style.opacity='1'"
          onmouseout="this.style.opacity='0.45'"
        />
      ))}
    </div>

    <div style="text-align: center; margin-top: 60px;">
      <a href="#portafolio" class="btn-cyan">Ver portafolio de experiencias</a>
    </div>
  </div>
</section>

<!-- ═══════════════════ SERVICES ═══════════════════ -->
<section id="servicios" style="padding: 100px 24px;">
  <div style="max-width: 1100px; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 20px;">
      <span class="tag">Nuestro diferencial</span>
    </div>
    <h2 style="
      font-family: 'eurostile', sans-serif;
      font-weight: 900;
      font-size: clamp(2rem, 5vw, 4rem);
      text-transform: uppercase;
      text-align: center;
      color: white;
      letter-spacing: 0.02em;
      line-height: 1;
      margin: 24px 0 52px;
    ">Lo que hacemos mejor que nadie</h2>

    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px;">
      {services.map(s => (
        <div style="position: relative; overflow: hidden; border-radius: 18px;">
          <img
            src={`${b}/images/services/${s.key}.png`}
            alt={s.label}
            style="width: 100%; height: 300px; object-fit: cover; display: block; transition: transform 0.6s ease;"
            onmouseover="this.style.transform='scale(1.04)'"
            onmouseout="this.style.transform='scale(1)'"
          />
          <div style="
            position: absolute; inset: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.2) 55%, transparent 100%);
          "></div>
          <div style="position: absolute; bottom: 0; left: 0; padding: 28px 32px; display: flex; align-items: center; gap: 10px;">
            <span style="color: #40DCFF; font-weight: 900; font-size: 1rem;">{s.icon}</span>
            <span style="
              font-family: 'eurostile', sans-serif;
              font-weight: 900;
              font-size: clamp(1rem, 1.8vw, 1.25rem);
              text-transform: uppercase;
              color: white;
              letter-spacing: 0.04em;
              line-height: 1.1;
            ">{s.label}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════ VALUES ═══════════════════ -->
<section style="padding: 100px 24px; position: relative;">
  <div style="max-width: 1060px; margin: 0 auto; display: grid; grid-template-columns: repeat(3,1fr); gap: 16px;">
    {values.map(v => (
      <div class="card" style="padding: 40px 32px;">
        <div style="
          font-family: 'eurostile', sans-serif;
          font-weight: 700;
          font-size: 0.65rem;
          color: #40DCFF;
          letter-spacing: 0.2em;
          margin-bottom: 24px;
        ">{v.num}</div>
        <h3 style="
          font-family: 'eurostile', sans-serif;
          font-weight: 900;
          font-size: 1.35rem;
          text-transform: uppercase;
          color: white;
          line-height: 1.15;
          margin-bottom: 16px;
          white-space: pre-line;
        ">{v.title}</h3>
        <p style="font-size: 0.85rem; color: rgba(255,255,255,0.4); line-height: 1.65;">{v.desc}</p>
      </div>
    ))}
  </div>
</section>

<!-- ═══════════════════ QUANTUM STUDIOS ═══════════════════ -->
<section style="padding: 100px 24px;">
  <div style="max-width: 1100px; margin: 0 auto;">
    <div style="position: relative; border-radius: 20px; overflow: hidden;">
      <img
        src={`${b}/images/quantum-studios.png`}
        alt="Quantum Studios"
        style="width: 100%; height: 480px; object-fit: cover; object-position: center; display: block;"
      />
      <div style="
        position: absolute; inset: 0;
        background: linear-gradient(to right, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.55) 45%, rgba(0,0,0,0.05) 100%);
      "></div>
      <div style="
        position: absolute; inset: 0;
        display: flex; flex-direction: column;
        justify-content: center;
        padding: 0 72px;
        max-width: 560px;
      ">
        <h2 style="
          font-family: 'eurostile', sans-serif;
          font-weight: 900;
          font-size: clamp(2.2rem, 4vw, 3.5rem);
          text-transform: uppercase;
          color: white;
          line-height: 1;
          letter-spacing: 0.02em;
          margin-bottom: 18px;
        ">Quantum Studios</h2>
        <p style="font-size: 0.92rem; color: rgba(255,255,255,0.5); line-height: 1.75; margin-bottom: 36px;">
          Un espacio para crear sin límites.<br/>
          Ubicado en el corazón de Lima, Perú.
        </p>
        <div><a href="#contacto" class="btn-ghost">Ver estudio</a></div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════ STAGE 01 ═══════════════════ -->
<section style="padding: 100px 24px; border-top: 1px solid rgba(255,255,255,0.05);">
  <div style="max-width: 1100px; margin: 0 auto; text-align: center;">
    <img
      src={`${b}/images/brands/stage01.svg`}
      alt="Stage 01"
      style="height: 48px; margin: 0 auto 24px; display: block; filter: brightness(10); opacity: 0.75;"
    />
    <span class="tag">El poder de crear, conectar y entretener</span>

    <div style="display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; margin-top: 60px;">
      {brands.map(b2 => (
        <div class="card" style="padding: 36px 24px; text-align: center;">
          <img
            src={`${b}/images/brands/${b2.key}.svg`}
            alt={b2.role}
            style="height: 34px; margin: 0 auto 20px; display: block; object-fit: contain; filter: brightness(10);"
          />
          <p style="
            font-family: 'eurostile', sans-serif;
            font-weight: 700;
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: white;
            margin-bottom: 8px;
          ">{b2.role}</p>
          <p style="font-size: 0.65rem; color: rgba(255,255,255,0.3); letter-spacing: 0.04em;">{b2.tags}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════ PORTFOLIO ═══════════════════ -->
<section id="portafolio" style="padding: 100px 24px; text-align: center;">
  <div style="max-width: 800px; margin: 0 auto;">
    <span class="tag" style="display: inline-flex; margin-bottom: 28px;">Portafolio</span>
    <h2 style="
      font-family: 'eurostile', sans-serif;
      font-weight: 900;
      font-size: clamp(2.5rem, 6vw, 5rem);
      text-transform: uppercase;
      line-height: 0.95;
      letter-spacing: 0.02em;
      margin: 0 0 20px;
    ">
      Experiencias que<br/><span class="gradient-text">dejan huella</span>
    </h2>
    <p style="font-size: 0.9rem; color: rgba(255,255,255,0.4); max-width: 480px; margin: 0 auto 48px; line-height: 1.75;">
      Más de 300 proyectos para las marcas más importantes del ecosistema gaming y entretenimiento en Latinoamérica.
    </p>
    <a href="#contacto" class="btn-cyan">Solicitar portafolio completo</a>
  </div>
</section>

<!-- ═══════════════════ CONTACT ═══════════════════ -->
<section id="contacto" style="padding: 100px 24px; border-top: 1px solid rgba(255,255,255,0.05);">
  <div style="max-width: 600px; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 60px;">
      <span class="tag" style="display: inline-flex; margin-bottom: 28px;">Contacto</span>
      <h2 style="
        font-family: 'eurostile', sans-serif;
        font-weight: 900;
        font-size: clamp(3rem, 7vw, 5.5rem);
        text-transform: uppercase;
        line-height: 0.9;
        letter-spacing: 0.01em;
      ">
        Trabajemos<br/><span class="gradient-text">juntos</span>
      </h2>
    </div>

    <form style="display: flex; flex-direction: column; gap: 14px;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px;">
        <input type="text" placeholder="Nombre" style="
          background: rgba(15,14,21,0.6);
          border: 1px solid rgba(255,255,255,0.1);
          border-radius: 10px;
          padding: 15px 20px;
          color: white;
          font-family: 'eurostile', sans-serif;
          font-size: 0.82rem;
          outline: none;
          transition: border-color 0.2s;
        " onfocus="this.style.borderColor='rgba(64,220,255,0.5)'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'" />
        <input type="email" placeholder="Email" style="
          background: rgba(15,14,21,0.6);
          border: 1px solid rgba(255,255,255,0.1);
          border-radius: 10px;
          padding: 15px 20px;
          color: white;
          font-family: 'eurostile', sans-serif;
          font-size: 0.82rem;
          outline: none;
          transition: border-color 0.2s;
        " onfocus="this.style.borderColor='rgba(64,220,255,0.5)'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'" />
      </div>
      <input type="text" placeholder="Empresa" style="
        background: rgba(15,14,21,0.6);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 10px;
        padding: 15px 20px;
        color: white;
        font-family: 'eurostile', sans-serif;
        font-size: 0.82rem;
        outline: none;
        transition: border-color 0.2s;
      " onfocus="this.style.borderColor='rgba(64,220,255,0.5)'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'" />
      <textarea placeholder="Cuéntanos sobre tu proyecto" rows="5" style="
        background: rgba(15,14,21,0.6);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 10px;
        padding: 15px 20px;
        color: white;
        font-family: 'eurostile', sans-serif;
        font-size: 0.82rem;
        outline: none;
        resize: none;
        transition: border-color 0.2s;
      " onfocus="this.style.borderColor='rgba(64,220,255,0.5)'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'"></textarea>
      <div style="text-align: center; padding-top: 8px;">
        <button type="submit" class="btn-cyan" style="padding: 0.7rem 4rem; cursor: pointer;">Enviar mensaje</button>
      </div>
    </form>
  </div>
</section>

</Layout>

<style>
  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }
</style>
