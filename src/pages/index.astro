---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

const stats = [
  { value: '+300', label: 'Proyectos' },
  { value: '+80', label: 'Clientes' },
  { value: '+5M', label: 'Impactos' },
];

const clients = [
  'utp','pucp','betplay','yape','amd','bitel','continental',
  'aorus','logitech','intel','razer','spacefwd',
  'rivalry','valve','claro','acer','moonton',
];

const services = [
  { key: 'estrategia', icon: '▼', title: 'Estrategia &', title2: 'Campañas' },
  { key: 'talentos', icon: '◆', title: 'Talentos', title2: '& Comunidad' },
  { key: 'produccion', icon: '+', title: 'Producción &', title2: 'Contenido' },
  { key: 'eventos', icon: '●', title: 'Eventos &', title2: 'Experiencias en Vivo' },
];

const values = [
  { num: '01', title: 'Nada es relleno', desc: 'Hasta lo que no se ve' },
  { num: '02', title: 'Hecho para vivirse', desc: 'Cada decisión empieza por la experiencia' },
  { num: '03', title: 'Bueno no es suficiente', desc: 'El estándar no se negocia' },
];

const brands = [
  { key: 'brandora', name: 'Brandora', role: 'Agencia de Marketing', tags: 'Estrategia · Campaña · Marca' },
  { key: 'wonder', name: 'Wonder', role: 'Productora de Eventos', tags: 'Experiencia · Activaciones · BTL' },
  { key: 'intercut', name: 'Intercut Media', role: 'Productora Audiovisual', tags: 'Ideas · Contenido · Todo Formato' },
  { key: 'quantum', name: 'Quantum Infinity', role: 'Entretenimiento & Gaming', tags: 'Juego · Cultura · Comunidad' },
];
---

<Layout title="Quantum Infinity — Entertainment Powered by Gaming">

  <!-- HERO -->
  <section class="relative min-h-screen flex flex-col items-center justify-center text-center px-6 pt-24 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0d1a3a]/60 via-[#070b18] to-[#070b18] pointer-events-none"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-[#00d4ff]/5 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="relative z-10 max-w-4xl mx-auto">
      <span class="section-tag mb-8 inline-block">No existen recetas secretas</span>

      <h1 class="font-['Barlow_Condensed'] text-6xl md:text-8xl font-black uppercase leading-none tracking-tight mb-4">
        <span class="gradient-text">Entertainment</span><br/>
        <span class="text-white">Powered by Gaming</span>
      </h1>

      <div class="mt-6 space-y-1 text-white/40 font-['Barlow_Condensed'] text-xl md:text-2xl uppercase font-bold tracking-widest">
        <p>Gaming es <span class="text-white/60">Entretenimiento</span></p>
        <p class="text-white/25">Cultura · Experiencia · Comunidad</p>
      </div>

      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#servicios" class="btn-outline">Ver servicios</a>
        <a href="#contacto" class="btn-solid">Trabajemos juntos</a>
      </div>
    </div>

    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
      <svg width="20" height="20" fill="none" stroke="#00d4ff" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </section>

  <!-- STATS -->
  <section class="py-20 border-y border-white/5" id="nosotros">
    <div class="max-w-4xl mx-auto px-6">
      <div class="grid grid-cols-3 gap-8 text-center">
        {stats.map(s => (
          <div>
            <div class="font-['Barlow_Condensed'] text-5xl md:text-7xl font-black text-[#00d4ff] leading-none">{s.value}</div>
            <div class="font-['Barlow_Condensed'] text-sm md:text-base font-bold uppercase tracking-[0.2em] text-white mt-2">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CLIENTS -->
  <section class="py-20 px-6">
    <div class="max-w-5xl mx-auto">
      <p class="text-center text-white/40 text-xs uppercase tracking-[0.2em] font-bold mb-10">Marcas que han confiado en nosotros</p>
      <div class="flex flex-wrap justify-center items-center gap-x-10 gap-y-6">
        {clients.map(c => (
          <img
            src={`${base}images/clients/${c}.svg`}
            alt={c}
            class="h-6 md:h-7 object-contain opacity-50 hover:opacity-100 transition-opacity duration-300 brightness-[200]"
          />
        ))}
      </div>
      <div class="text-center mt-12">
        <a href="#portafolio" class="btn-outline">Ver portafolio de experiencias</a>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="py-24 px-6" id="servicios">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-4">
        <span class="section-tag">Nuestro diferencial</span>
      </div>
      <h2 class="font-['Barlow_Condensed'] text-4xl md:text-6xl font-black uppercase text-center text-white mt-6 mb-12">
        Lo que hacemos mejor que nadie
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {services.map(s => (
          <div class="relative overflow-hidden rounded-xl group cursor-pointer">
            <img
              src={`${base}images/services/${s.key}.png`}
              alt={`${s.title} ${s.title2}`}
              class="w-full h-64 object-cover group-hover:scale-105 transition-transform duration-500"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#070b18]/90 via-[#070b18]/30 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-6">
              <span class="text-[#00d4ff] font-bold mr-2">{s.icon}</span>
              <span class="font-['Barlow_Condensed'] text-xl md:text-2xl font-black uppercase text-white">
                {s.title}<br/>{s.title2}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section class="py-24 px-6 bg-[#0a0f1e]">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {values.map(v => (
          <div class="card-dark p-8">
            <div class="text-[#00d4ff] font-['Barlow_Condensed'] text-sm font-bold tracking-widest mb-4">{v.num}</div>
            <h3 class="font-['Barlow_Condensed'] text-2xl font-black uppercase text-white leading-tight mb-3">{v.title}</h3>
            <p class="text-white/50 text-sm">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- QUANTUM STUDIOS -->
  <section class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="relative rounded-2xl overflow-hidden">
        <img
          src={`${base}images/quantum-studios.png`}
          alt="Quantum Studios"
          class="w-full h-[420px] object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-[#070b18]/95 via-[#070b18]/60 to-transparent"></div>
        <div class="absolute inset-0 flex flex-col justify-center px-10 md:px-16 max-w-lg">
          <h2 class="font-['Barlow_Condensed'] text-4xl md:text-5xl font-black uppercase text-white leading-tight mb-3">
            Quantum Studios
          </h2>
          <p class="text-white/60 text-sm mb-8 leading-relaxed">
            Un espacio para crear sin límites.<br/>
            Ubicado en el corazón de Lima, Perú.
          </p>
          <a href="#contacto" class="btn-solid w-fit">Ver estudio</a>
        </div>
      </div>
    </div>
  </section>

  <!-- STAGE 01 BRANDS -->
  <section class="py-24 px-6 border-t border-white/5">
    <div class="max-w-6xl mx-auto text-center">
      <img src={`${base}images/brands/stage01.svg`} alt="Stage 01" class="h-10 mx-auto mb-6 opacity-80 brightness-[200]" />
      <span class="section-tag inline-block">El poder de crear, conectar y entretener</span>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mt-12">
        {brands.map(b => (
          <div class="card-dark p-6 text-center hover:border-[#00d4ff]/40 transition-colors duration-300">
            <img
              src={`${base}images/brands/${b.key}.svg`}
              alt={b.name}
              class="h-8 mx-auto mb-4 object-contain brightness-[200]"
            />
            <p class="text-white font-bold text-sm">{b.role}</p>
            <p class="text-white/40 text-xs mt-1">{b.tags}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PORTFOLIO -->
  <section class="py-24 px-6 bg-[#0a0f1e]" id="portafolio">
    <div class="max-w-6xl mx-auto text-center">
      <span class="section-tag mb-6 inline-block">Portafolio</span>
      <h2 class="font-['Barlow_Condensed'] text-4xl md:text-6xl font-black uppercase text-white mt-4 mb-4">
        Experiencias que <span class="gradient-text">dejan huella</span>
      </h2>
      <p class="text-white/50 text-sm mb-10 max-w-xl mx-auto">
        Más de 300 proyectos para las marcas más importantes del ecosistema gaming y entretenimiento en Latinoamérica.
      </p>
      <a href="#contacto" class="btn-outline">Solicitar portafolio completo</a>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="py-24 px-6" id="contacto">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-12">
        <span class="section-tag mb-6 inline-block">Contacto</span>
        <h2 class="font-['Barlow_Condensed'] text-4xl md:text-6xl font-black uppercase text-white mt-4">
          Trabajemos<br/><span class="gradient-text">juntos</span>
        </h2>
      </div>

      <form class="space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <input
            type="text"
            placeholder="Nombre"
            class="w-full bg-[#0d1220] border border-white/10 rounded-lg px-4 py-3 text-white text-sm placeholder-white/30 focus:outline-none focus:border-[#00d4ff]/50 transition-colors"
          />
          <input
            type="email"
            placeholder="Email"
            class="w-full bg-[#0d1220] border border-white/10 rounded-lg px-4 py-3 text-white text-sm placeholder-white/30 focus:outline-none focus:border-[#00d4ff]/50 transition-colors"
          />
        </div>
        <input
          type="text"
          placeholder="Empresa"
          class="w-full bg-[#0d1220] border border-white/10 rounded-lg px-4 py-3 text-white text-sm placeholder-white/30 focus:outline-none focus:border-[#00d4ff]/50 transition-colors"
        />
        <textarea
          placeholder="Cuéntanos sobre tu proyecto"
          rows="5"
          class="w-full bg-[#0d1220] border border-white/10 rounded-lg px-4 py-3 text-white text-sm placeholder-white/30 focus:outline-none focus:border-[#00d4ff]/50 transition-colors resize-none"
        ></textarea>
        <div class="text-center pt-2">
          <button type="submit" class="btn-outline px-12">Enviar mensaje</button>
        </div>
      </form>
    </div>
  </section>

</Layout>
