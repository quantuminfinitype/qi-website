---
import Layout from '../layouts/Layout.astro';
const b = import.meta.env.BASE_URL.replace(/\/$/, '');

const stats = [
  { value: '+300', label: 'Proyectos' },
  { value: '+80',  label: 'Clientes' },
  { value: '+5M',  label: 'Impactos' },
];

const clients = [
  'utp','pucp','betplay','yape','amd','bitel','continental',
  'aorus','nvidia','logitech','intel','razer','spacefwd',
  'rivalry','valve','claro','acer','moonton',
];

const services = [
  { key: 'estrategia', icon: '▼', label: 'Estrategia &\nCampañas' },
  { key: 'talentos',   icon: '◆', label: 'Talentos\n& Comunidad' },
  { key: 'produccion', icon: '+', label: 'Producción &\nContenido' },
  { key: 'eventos',    icon: '●', label: 'Eventos &\nExperiencias en Vivo' },
];

const values = [
  { num: '01', title: 'Nada\nes relleno',       desc: 'Hasta lo que no se ve' },
  { num: '02', title: 'Hecho para\nvivirse',     desc: 'Cada decisión empieza por la experiencia' },
  { num: '03', title: 'Bueno no es\nsuficiente', desc: 'El estándar no se negocia' },
];

const brands = [
  { key: 'brandora', name: 'Brandora',         role: 'Agencia de Marketing',     tags: 'Estrategia · Campaña · Marca' },
  { key: 'wonder',   name: 'Wonder',           role: 'Productora de Eventos',    tags: 'Experiencia · Activaciones · BTL' },
  { key: 'intercut', name: 'Intercut Media',   role: 'Productora Audiovisual',   tags: 'Ideas · Contenido · Todo Formato' },
  { key: 'quantum',  name: 'Quantum Infinity', role: 'Entretenimiento & Gaming', tags: 'Juego · Cultura · Comunidad' },
];
---

<Layout title="Quantum Infinity — Entertainment Powered by Gaming">

<!-- ══════════════════════════════════ HERO ══════════════════════════════════ -->
<section style="position:relative;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:140px 40px 100px;overflow:hidden;">

  <!-- ghost stacked words -->
  <div aria-hidden="true" style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;pointer-events:none;user-select:none;gap:2px;">
    <div style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(2rem,5.5vw,5rem);letter-spacing:0.06em;text-transform:uppercase;color:rgba(255,255,255,0.04);">CULTURA</div>
    <div style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(2rem,5.5vw,5rem);letter-spacing:0.06em;text-transform:uppercase;color:rgba(255,255,255,0.07);">EXPERIENCIA</div>
    <div style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(2rem,5.5vw,5rem);letter-spacing:0.06em;text-transform:uppercase;color:rgba(64,220,255,0.15);">ENTRETENIMIENTO</div>
    <div style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(2rem,5.5vw,5rem);letter-spacing:0.06em;text-transform:uppercase;color:rgba(255,255,255,0.05);">COMUNIDAD</div>
    <div style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(2rem,5.5vw,5rem);letter-spacing:0.06em;text-transform:uppercase;color:rgba(255,255,255,0.03);">CREATIVIDAD</div>
  </div>

  <div style="position:relative;z-index:10;max-width:980px;width:100%;">
    <span class="tag" style="display:inline-flex;margin-bottom:40px;">No existen recetas secretas</span>

    <h1 style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(3.5rem,9.5vw,9rem);text-transform:uppercase;line-height:0.9;letter-spacing:0.01em;margin:0 0 28px;">
      <span class="gradient-text" style="display:block;">Entertainment</span>
      <span style="color:white;display:block;">Powered by Gaming</span>
    </h1>

    <p style="font-family:'eurostile',sans-serif;font-weight:700;font-size:clamp(0.8rem,1.4vw,1rem);text-transform:uppercase;letter-spacing:0.12em;color:rgba(255,255,255,0.45);margin:0 0 48px;">
      Gaming es <span style="color:#40DCFF;">Entretenimiento</span>
      <span style="color:rgba(255,255,255,0.2);margin:0 12px;">·</span>
      <span style="color:rgba(255,255,255,0.2);">Cultura · Experiencia · Comunidad</span>
    </p>

    <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
      <a href="#servicios" class="btn-cyan">Ver servicios</a>
      <a href="#contacto" class="btn-ghost">Trabajemos juntos</a>
    </div>
  </div>

  <a href="#nosotros" style="position:absolute;bottom:36px;left:50%;transform:translateX(-50%);animation:bounce 2s infinite;opacity:0.6;">
    <svg width="18" height="18" fill="none" stroke="#40DCFF" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
    </svg>
  </a>
</section>

<!-- ══════════════════════════════════ STATS ══════════════════════════════════ -->
<section id="nosotros" style="padding:80px 40px;border-top:1px solid rgba(255,255,255,0.07);border-bottom:1px solid rgba(255,255,255,0.07);">
  <div style="max-width:820px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:20px;text-align:center;">
    {stats.map(s => (
      <div>
        <div style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(3.5rem,8vw,6.5rem);color:#40DCFF;line-height:1;letter-spacing:-0.02em;">{s.value}</div>
        <div style="font-family:'eurostile',sans-serif;font-weight:700;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.22em;color:white;margin-top:8px;">{s.label}</div>
      </div>
    ))}
  </div>
</section>

<!-- ══════════════════════════════════ CLIENTS ══════════════════════════════════ -->
<section style="padding:80px 40px;">
  <div style="max-width:1060px;margin:0 auto;">
    <div style="display:flex;flex-wrap:wrap;justify-content:center;align-items:center;gap:24px 44px;margin-bottom:56px;">
      {clients.map(c => (
        <img src={`${b}/images/clients/${c}.svg`} alt={c}
          style="height:20px;object-fit:contain;opacity:0.5;filter:brightness(10);transition:opacity 0.3s;"
          onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.5'" />
      ))}
    </div>
    <div style="text-align:center;">
      <a href="#portafolio" class="btn-cyan">Ver portafolio de experiencias</a>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════ QUANTUM STUDIOS ══════════════════════════════════ -->
<section style="padding:0 0 0 0;overflow:hidden;">
  <div style="display:grid;grid-template-columns:1fr 1fr;min-height:440px;">
    <!-- text side -->
    <div style="padding:80px 64px;display:flex;flex-direction:column;justify-content:center;background:rgba(6,8,18,0.6);">
      <h2 style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(1.8rem,3.5vw,2.8rem);text-transform:uppercase;color:white;line-height:1;letter-spacing:0.02em;margin:0 0 16px;">Quantum Studios</h2>
      <p style="font-size:0.9rem;color:rgba(255,255,255,0.5);line-height:1.75;margin:0 0 36px;">
        Un espacio para crear sin límites.<br/>Ubicado en el corazón de Lima, Perú.
      </p>
      <div><a href="#contacto" class="btn-ghost">Ver estudio</a></div>
    </div>
    <!-- photo side -->
    <div style="position:relative;overflow:hidden;">
      <img src={`${b}/images/quantum-studios.png`} alt="Quantum Studios"
        style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(to right,rgba(6,8,18,0.4) 0%,transparent 40%);"></div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════ STAGE 01 ══════════════════════════════════ -->
<section style="padding:100px 40px;text-align:center;">
  <div style="max-width:1100px;margin:0 auto;">
    <img src={`${b}/images/brands/stage01.svg`} alt="Stage 01"
      style="height:56px;margin:0 auto 24px;display:block;filter:brightness(10);opacity:0.85;" />
    <span class="tag">El poder de crear, conectar y entretener</span>

    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:64px;">
      {brands.map(br => (
        <div class="card" style="padding:36px 20px;text-align:center;">
          <img src={`${b}/images/brands/${br.key}.svg`} alt={br.name}
            style="height:32px;margin:0 auto 18px;display:block;object-fit:contain;filter:brightness(10);" />
          <p style="font-family:'eurostile',sans-serif;font-weight:700;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.06em;color:white;margin:0 0 6px;">{br.role}</p>
          <p style="font-size:0.65rem;color:rgba(255,255,255,0.3);letter-spacing:0.03em;">{br.tags}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════ SERVICES ══════════════════════════════════ -->
<section id="servicios" style="padding:100px 40px;">
  <div style="max-width:1100px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:20px;">
      <span class="tag">Nuestro diferencial</span>
    </div>
    <h2 style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(1.8rem,4.5vw,3.5rem);text-transform:uppercase;text-align:center;color:white;letter-spacing:0.02em;line-height:1;margin:24px 0 48px;">
      Lo que hacemos mejor que nadie
    </h2>
    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:10px;">
      {services.map(s => (
        <div style="position:relative;overflow:hidden;border-radius:18px;cursor:pointer;">
          <img src={`${b}/images/services/${s.key}.png`} alt={s.label}
            style="width:100%;height:290px;object-fit:cover;display:block;transition:transform 0.5s ease;"
            onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform='scale(1)'" />
          <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.8) 0%,rgba(0,0,0,0.15) 55%,transparent 100%);"></div>
          <div style="position:absolute;bottom:0;left:0;padding:24px 28px;display:flex;align-items:flex-end;gap:10px;">
            <span style="color:#40DCFF;font-weight:900;font-size:0.9rem;line-height:1;">{s.icon}</span>
            <span style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(0.9rem,1.6vw,1.15rem);text-transform:uppercase;color:white;letter-spacing:0.04em;line-height:1.15;white-space:pre-line;">{s.label}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════ VALUES ══════════════════════════════════ -->
<section style="padding:100px 40px;">
  <div style="max-width:1060px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:14px;">
    {values.map(v => (
      <div class="card" style="padding:40px 28px;">
        <div style="font-family:'eurostile',sans-serif;font-weight:700;font-size:0.65rem;color:#40DCFF;letter-spacing:0.2em;margin-bottom:22px;">{v.num}</div>
        <h3 style="font-family:'eurostile',sans-serif;font-weight:900;font-size:1.25rem;text-transform:uppercase;color:white;line-height:1.15;margin:0 0 14px;white-space:pre-line;">{v.title}</h3>
        <p style="font-size:0.84rem;color:rgba(255,255,255,0.4);line-height:1.65;margin:0;">{v.desc}</p>
      </div>
    ))}
  </div>
</section>

<!-- ══════════════════════════════════ PORTFOLIO ══════════════════════════════════ -->
<section id="portafolio" style="padding:100px 40px;text-align:center;border-top:1px solid rgba(255,255,255,0.05);">
  <div style="max-width:800px;margin:0 auto;">
    <span class="tag" style="display:inline-flex;margin-bottom:28px;">Portafolio</span>
    <h2 style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(2.5rem,6vw,5rem);text-transform:uppercase;line-height:0.92;letter-spacing:0.01em;margin:0 0 20px;">
      Experiencias que<br/><span class="gradient-text">dejan huella</span>
    </h2>
    <p style="font-size:0.9rem;color:rgba(255,255,255,0.4);max-width:460px;margin:0 auto 48px;line-height:1.75;">
      Más de 300 proyectos para las marcas más importantes del ecosistema gaming y entretenimiento en Latinoamérica.
    </p>
    <a href="#contacto" class="btn-cyan">Solicitar portafolio completo</a>
  </div>
</section>

<!-- ══════════════════════════════════ CONTACT ══════════════════════════════════ -->
<section id="contacto" style="position:relative;padding:140px 40px;text-align:center;overflow:hidden;min-height:80vh;display:flex;align-items:center;justify-content:center;">

  <!-- giant Q outline background -->
  <div aria-hidden="true" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none;">
    <svg viewBox="0 0 400 400" style="width:min(700px,90vw);height:min(700px,90vw);opacity:0.04;" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M200 40C111.6 40 40 111.6 40 200C40 288.4 111.6 360 200 360C245.2 360 286.2 341.6 316 312L340 336L360 316L336 292C354 263.2 364 229 364 200C364 111.6 288.4 40 200 40ZM200 320C133.7 320 80 266.3 80 200C80 133.7 133.7 80 200 80C266.3 80 320 133.7 320 200C320 226.8 311.4 251.6 296.6 271.6L264 239L244 259L276.6 291.6C257.4 308.6 232.8 320 200 320Z" fill="white"/>
    </svg>
  </div>

  <div style="position:relative;z-index:10;max-width:700px;width:100%;">
    <h2 style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(2.8rem,7vw,6rem);text-transform:uppercase;line-height:0.9;letter-spacing:0.01em;margin:0 0 56px;">
      Hagamos algo<br/>
      <span class="gradient-text">Épico</span>
      <span style="color:white;"> Juntos</span>
    </h2>

    <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
      <a href="https://wa.me/51999999999" target="_blank" class="btn-ghost">WhatsApp</a>
      <a href="mailto:hola@qi.pe" class="btn-ghost">Email</a>
      <a href="https://t.me/quantuminfinity" target="_blank" class="btn-ghost">Telegram</a>
    </div>
  </div>
</section>

</Layout>

<style>
  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }
</style>
