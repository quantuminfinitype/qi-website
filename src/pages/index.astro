---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const img = (path: string) => `${base}/${path}`;

const stats = [
  { value: '+300', label: 'Proyectos' },
  { value: '+80', label: 'Clientes' },
  { value: '+5M', label: 'Impactos' },
];

const clients = [
  'utp','pucp','betplay','yape','amd','bitel','continental',
  'aorus','nvidia','logitech','intel','razer','spacefwd',
  'rivalry','valve','claro','acer','moonton',
];

const services = [
  { key: 'estrategia', icon: '▼', label: 'Estrategia & Campañas' },
  { key: 'talentos',   icon: '◆', label: 'Talentos & Comunidad' },
  { key: 'produccion', icon: '+', label: 'Producción & Contenido' },
  { key: 'eventos',    icon: '●', label: 'Eventos & Experiencias en Vivo' },
];

const values = [
  { num: '01', title: 'Nada es relleno',           desc: 'Hasta lo que no se ve' },
  { num: '02', title: 'Hecho para vivirse',         desc: 'Cada decisión empieza por la experiencia' },
  { num: '03', title: 'Bueno no es suficiente',     desc: 'El estándar no se negocia' },
];

const brands = [
  { key: 'brandora', name: 'Brandora',         role: 'Agencia de Marketing',     tags: 'Estrategia · Campaña · Marca' },
  { key: 'wonder',   name: 'Wonder',           role: 'Productora de Eventos',    tags: 'Experiencia · Activaciones · BTL' },
  { key: 'intercut', name: 'Intercut Media',   role: 'Productora Audiovisual',   tags: 'Ideas · Contenido · Todo Formato' },
  { key: 'quantum',  name: 'Quantum Infinity', role: 'Entretenimiento & Gaming', tags: 'Juego · Cultura · Comunidad' },
];
---

<Layout title="Quantum Infinity — Entertainment Powered by Gaming">

  <!-- ═══════════════════════════════════════════════════ HERO -->
  <section style="min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:120px 24px 80px;position:relative;overflow:hidden;">
    <!-- background glow -->
    <div style="position:absolute;top:-100px;left:50%;transform:translateX(-50%);width:900px;height:600px;background:radial-gradient(ellipse at center,rgba(0,100,180,0.18) 0%,transparent 70%);pointer-events:none;"></div>

    <!-- stacked background words -->
    <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0;pointer-events:none;user-select:none;">
      {['CULTURA','EXPERIENCIA','COMUNIDAD','CREATIVIDAD','ESTRATEGIA'].map((w,i) => (
        <div style={`font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(3rem,7vw,6rem);letter-spacing:0.05em;color:rgba(255,255,255,${0.03 + i*0.015});text-transform:uppercase;line-height:1.1;`}>{w}</div>
      ))}
    </div>

    <div style="position:relative;z-index:10;max-width:900px;margin:0 auto;">
      <span class="tag" style="margin-bottom:32px;display:inline-flex;">No existen recetas secretas</span>

      <h1 style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(3.5rem,9vw,8rem);text-transform:uppercase;line-height:0.95;letter-spacing:0.02em;margin:0 0 24px;">
        <span class="gradient-text">Entertainment</span><br/>
        <span style="color:white;">Powered by Gaming</span>
      </h1>

      <p style="font-family:'eurostile',sans-serif;font-size:1.1rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.5);margin:0 0 8px;">
        Gaming es <span style="color:rgba(255,255,255,0.8);">Entretenimiento</span>
      </p>
      <p style="font-family:'eurostile',sans-serif;font-size:0.85rem;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:rgba(255,255,255,0.25);margin:0 0 48px;">
        Cultura · Experiencia · Comunidad
      </p>

      <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
        <a href="#servicios" class="btn-cyan">Ver servicios</a>
        <a href="#contacto" class="btn-ghost">Trabajemos juntos</a>
      </div>
    </div>

    <div style="position:absolute;bottom:32px;left:50%;transform:translateX(-50%);animation:bounce 2s infinite;">
      <svg width="20" height="20" fill="none" stroke="#00d4ff" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ STATS -->
  <section id="nosotros" style="padding:80px 24px;border-top:1px solid rgba(255,255,255,0.06);border-bottom:1px solid rgba(255,255,255,0.06);">
    <div style="max-width:800px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:40px;text-align:center;">
      {stats.map(s => (
        <div>
          <div style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(3rem,7vw,5.5rem);color:#00d4ff;line-height:1;">{s.value}</div>
          <div style="font-family:'eurostile',sans-serif;font-weight:700;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.2em;color:white;margin-top:8px;">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ CLIENTS -->
  <section style="padding:80px 24px;">
    <div style="max-width:1000px;margin:0 auto;">
      <p style="text-align:center;font-family:'eurostile',sans-serif;font-size:0.62rem;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;color:rgba(255,255,255,0.35);margin-bottom:48px;">
        Marcas que han confiado en nosotros
      </p>
      <div style="display:flex;flex-wrap:wrap;justify-content:center;align-items:center;gap:32px 48px;">
        {clients.map(c => (
          <img src={img(`images/clients/${c}.svg`)} alt={c}
            style="height:24px;object-fit:contain;opacity:0.45;filter:brightness(200);transition:opacity 0.3s;"
            onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.45'"
          />
        ))}
      </div>
      <div style="text-align:center;margin-top:56px;">
        <a href="#portafolio" class="btn-cyan">Ver portafolio de experiencias</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ SERVICES -->
  <section id="servicios" style="padding:96px 24px;">
    <div style="max-width:1100px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:16px;">
        <span class="tag">Nuestro diferencial</span>
      </div>
      <h2 style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(2rem,5vw,4rem);text-transform:uppercase;text-align:center;color:white;margin:24px 0 48px;letter-spacing:0.02em;">
        Lo que hacemos mejor que nadie
      </h2>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;">
        {services.map(s => (
          <div style="position:relative;overflow:hidden;border-radius:12px;cursor:pointer;group;">
            <img src={img(`images/services/${s.key}.png`)} alt={s.label}
              style="width:100%;height:280px;object-fit:cover;display:block;transition:transform 0.5s;"
              onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'"
            />
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(7,11,24,0.92) 0%,rgba(7,11,24,0.3) 50%,transparent 100%);"></div>
            <div style="position:absolute;bottom:0;left:0;padding:24px 28px;">
              <span style="color:#00d4ff;font-weight:900;margin-right:8px;">{s.icon}</span>
              <span style="font-family:'eurostile',sans-serif;font-weight:900;font-size:1.15rem;text-transform:uppercase;color:white;letter-spacing:0.04em;">{s.label}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ VALUES -->
  <section style="padding:96px 24px;background:#0a0f1e;">
    <div style="max-width:1000px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:20px;">
      {values.map(v => (
        <div class="card" style="padding:36px 28px;transition:border-color 0.3s;">
          <div style="font-family:'eurostile',sans-serif;font-weight:700;font-size:0.7rem;color:#00d4ff;letter-spacing:0.2em;margin-bottom:20px;">{v.num}</div>
          <h3 style="font-family:'eurostile',sans-serif;font-weight:900;font-size:1.3rem;text-transform:uppercase;color:white;line-height:1.2;margin:0 0 14px;">{v.title}</h3>
          <p style="font-size:0.85rem;color:rgba(255,255,255,0.45);margin:0;line-height:1.6;">{v.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ QUANTUM STUDIOS -->
  <section style="padding:96px 24px;">
    <div style="max-width:1100px;margin:0 auto;">
      <div style="position:relative;border-radius:16px;overflow:hidden;">
        <img src={img('images/quantum-studios.png')} alt="Quantum Studios"
          style="width:100%;height:460px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(to right,rgba(7,11,24,0.95) 0%,rgba(7,11,24,0.6) 50%,rgba(7,11,24,0.1) 100%);"></div>
        <div style="position:absolute;inset:0;display:flex;flex-direction:column;justify-content:center;padding:0 64px;max-width:520px;">
          <h2 style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(2rem,4vw,3.2rem);text-transform:uppercase;color:white;line-height:1.1;margin:0 0 16px;letter-spacing:0.02em;">
            Quantum Studios
          </h2>
          <p style="font-size:0.9rem;color:rgba(255,255,255,0.55);line-height:1.7;margin:0 0 36px;">
            Un espacio para crear sin límites.<br/>Ubicado en el corazón de Lima, Perú.
          </p>
          <div><a href="#contacto" class="btn-ghost">Ver estudio</a></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ STAGE 01 -->
  <section style="padding:96px 24px;border-top:1px solid rgba(255,255,255,0.05);">
    <div style="max-width:1100px;margin:0 auto;text-align:center;">
      <img src={img('images/brands/stage01.svg')} alt="Stage 01"
        style="height:44px;margin:0 auto 20px;display:block;filter:brightness(200);opacity:0.7;" />
      <span class="tag">El poder de crear, conectar y entretener</span>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-top:56px;">
        {brands.map(b => (
          <div class="card" style="padding:32px 20px;text-align:center;transition:border-color 0.3s;">
            <img src={img(`images/brands/${b.key}.svg`)} alt={b.name}
              style="height:32px;margin:0 auto 20px;display:block;object-fit:contain;filter:brightness(200);" />
            <p style="font-family:'eurostile',sans-serif;font-weight:700;font-size:0.78rem;color:white;margin:0 0 6px;text-transform:uppercase;letter-spacing:0.05em;">{b.role}</p>
            <p style="font-size:0.7rem;color:rgba(255,255,255,0.35);margin:0;">{b.tags}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ PORTFOLIO -->
  <section id="portafolio" style="padding:96px 24px;background:#0a0f1e;">
    <div style="max-width:900px;margin:0 auto;text-align:center;">
      <span class="tag" style="margin-bottom:24px;display:inline-flex;">Portafolio</span>
      <h2 style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(2rem,5vw,4rem);text-transform:uppercase;color:white;margin:24px 0 16px;letter-spacing:0.02em;">
        Experiencias que <span class="gradient-text">dejan huella</span>
      </h2>
      <p style="font-size:0.9rem;color:rgba(255,255,255,0.45);max-width:520px;margin:0 auto 48px;line-height:1.7;">
        Más de 300 proyectos para las marcas más importantes del ecosistema gaming y entretenimiento en Latinoamérica.
      </p>
      <a href="#contacto" class="btn-cyan">Solicitar portafolio completo</a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ CONTACT -->
  <section id="contacto" style="padding:96px 24px;">
    <div style="max-width:640px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:56px;">
        <span class="tag" style="margin-bottom:24px;display:inline-flex;">Contacto</span>
        <h2 style="font-family:'eurostile',sans-serif;font-weight:900;font-size:clamp(2.5rem,6vw,5rem);text-transform:uppercase;color:white;margin:24px 0 0;letter-spacing:0.02em;line-height:0.95;">
          Trabajemos<br/><span class="gradient-text">juntos</span>
        </h2>
      </div>
      <form style="display:flex;flex-direction:column;gap:14px;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <input type="text" placeholder="Nombre"
            style="background:rgba(13,18,32,0.8);border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:14px 18px;color:white;font-family:'eurostile',sans-serif;font-size:0.85rem;outline:none;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='rgba(0,212,255,0.5)'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'"
          />
          <input type="email" placeholder="Email"
            style="background:rgba(13,18,32,0.8);border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:14px 18px;color:white;font-family:'eurostile',sans-serif;font-size:0.85rem;outline:none;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='rgba(0,212,255,0.5)'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'"
          />
        </div>
        <input type="text" placeholder="Empresa"
          style="background:rgba(13,18,32,0.8);border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:14px 18px;color:white;font-family:'eurostile',sans-serif;font-size:0.85rem;outline:none;transition:border-color 0.2s;"
          onfocus="this.style.borderColor='rgba(0,212,255,0.5)'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'"
        />
        <textarea placeholder="Cuéntanos sobre tu proyecto" rows="5"
          style="background:rgba(13,18,32,0.8);border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:14px 18px;color:white;font-family:'eurostile',sans-serif;font-size:0.85rem;outline:none;resize:none;transition:border-color 0.2s;"
          onfocus="this.style.borderColor='rgba(0,212,255,0.5)'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'"
        ></textarea>
        <div style="text-align:center;padding-top:8px;">
          <button type="submit" class="btn-cyan" style="padding:0.65rem 4rem;">Enviar mensaje</button>
        </div>
      </form>
    </div>
  </section>

</Layout>

<style>
  @keyframes bounce {
    0%,100% { transform:translateX(-50%) translateY(0); }
    50% { transform:translateX(-50%) translateY(8px); }
  }
</style>
